{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "export DIRECT_URL=${DIRECT_URL:-$(echo $DATABASE_URL | sed 's/6543/5432/' | sed 's/\\?pgbouncer=true//')} && bun run build",
  "installCommand": "bun install",
  "devCommand": "bun run dev",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
