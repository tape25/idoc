# ===========================================
# CONFIGURATION SUPABASE + VERCEL
# ===========================================
# 
# IMPORTANT: Vous devez configurer ces variables dans Vercel Dashboard
# Settings > Environment Variables
#
# Les deux URLs doivent utiliser le POOLER SUPABASE (IPv4)
# ===========================================

# DATABASE_URL - Mode Transaction (port 6543) pour les requêtes
# Format: postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.uvbxhvvgppgsganeqmzh:Choupi%402509@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL - Mode Session (port 5432) pour les migrations
# Format: postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.uvbxhvvgppgsganeqmzh:Choupi%402509@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================

# NEXTAUTH_SECRET - Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="sb_publishable_35QVHTNFXgVXiuDrm9sh0Q_nk09jxdZ"

# NEXTAUTH_URL - URL de production Vercel
NEXTAUTH_URL="https://idocmsvercel.app"

# ===========================================
# INSTRUCTIONS
# ===========================================
# 
# 1. Vérifiez la RÉGION correcte dans Supabase Dashboard:
#    - Settings > Database > Connection Pooler
#    - Remplacez "eu-west-3" par votre région réelle
#
# 2. Régions possibles: eu-west-1, eu-west-2, eu-west-3, us-east-1, us-east-2, us-west-1
#
# 3. Les deux URLs utilisent le POOLER (pas la connexion directe)
#    - DATABASE_URL: port 6543 (Transaction mode)
#    - DIRECT_URL: port 5432 (Session mode du pooler)
