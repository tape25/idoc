# ===========================================
# CONFIGURATION SUPABASE + VERCEL
# ===========================================

# DATABASE_URL - Connection Pooler (IPv4) pour Vercel
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL - Connexion directe pour les migrations Prisma
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================

# NEXTAUTH_SECRET - Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl"

# NEXTAUTH_URL - URL de production Vercel
NEXTAUTH_URL="https://idocmsvercel.app"

# ===========================================
# INSTRUCTIONS DE CONFIGURATION
# ===========================================
# 
# 1. Aller sur Supabase Dashboard > Settings > Database
# 2. Copier les URLs du Connection Pooler (Supavisor):
#    - Transaction mode (port 6543) -> DATABASE_URL
#    - Session mode ou direct -> DIRECT_URL
#
# 3. Sur Vercel Dashboard > Project > Settings > Environment Variables:
#    - Ajouter DATABASE_URL avec l'URL du pooler
#    - Ajouter DIRECT_URL avec l'URL directe
#    - Ajouter NEXTAUTH_SECRET
#    - Ajouter NEXTAUTH_URL=https://idocmsvercel.app
#
# 4. Redéployer le projet
